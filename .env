# LonghorNet local environment
# Copy and fill real secrets before using production services.

# --- App ---
NODE_ENV=development
APP_ENV=local
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Convex ---
CONVEX_DEPLOYMENT=dev:your-deployment-name
CONVEX_URL=https://your-deployment-name.convex.cloud
NEXT_PUBLIC_CONVEX_URL=https://your-deployment-name.convex.cloud

# --- OpenAI ---
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o

# --- Browser Use v1.0 (Local primary, mock fallback optional) ---
BROWSER_USE_API_KEY=bu_QaSVFN4UT_j4TpO_sIaGc1u-RBY7pijEH1Eihsxnn70
BROWSER_USE_BASE_URL=https://api.browser-use.com
BROWSER_USE_MODE=local_v1
BROWSER_USE_FALLBACK_ENABLED=true
BROWSER_USE_PYTHON_BIN=.venv/bin/python
BROWSER_USE_LOCAL_RUNNER_PATH=services/agents/browser_use_v1_runner.py
BROWSER_USE_CHROME_EXECUTABLE=
BROWSER_USE_USER_DATA_DIR=~/Library/Application Support/Google/Chrome
BROWSER_USE_PROFILE_DIRECTORY=Default
BROWSER_USE_HEADLESS=false
BROWSER_USE_HOLD_OPEN_SECONDS=10
BROWSER_USE_SCHOLAR_SEARCH_URL=https://utexas.scholarships.ngwebsolutions.com/ScholarX_StudentLanding.aspx
BROWSER_USE_DEFAULT_TASK_PROMPT=

# --- Auth (optional / stretch) ---
UT_SSO_CLIENT_ID=
UT_SSO_CLIENT_SECRET=
UT_SSO_ISSUER=
UT_SSO_REDIRECT_URI=http://localhost:3000/api/auth/callback/ut

# --- Runtime / Observability ---
LOG_LEVEL=info
RUNTIME_DETERMINISTIC_MOCK=true
REQUEST_TIMEOUT_SECONDS=60
